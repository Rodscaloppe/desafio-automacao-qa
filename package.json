{
  "name": "projeto-desafio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:contract": "jest contract/",
    "test:api": "jest api/ --config jest.api.config.js",
    "report:generate": "node scripts/generateReport.js",
    "cy:run:report": "npm run cy:run || true && npm run report:generate",
    "rca": "node scripts/rcaAgent.js",
    "heal": "node scripts/autoHealingAgent.js",
    "report-bug": "node scripts/trelloBugReporterAgent.js",
    "setup-trello": "node scripts/setupTrelloBoard.js",
    "test:all": "npm run test:api || true && npm run cy:run || true && npm run report:generate"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/support/stepDefinitions/**/*.js"
    ],
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-json/cucumber-report.json",
      "formatter": ".bin/cucumber-json-formatter"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@faker-js/faker": "^9.9.0",
    "@pact-foundation/pact": "^16.5.0",
    "axe-core": "^4.12.1",
    "axios": "^1.18.1",
    "babel-jest": "^30.4.1",
    "cypress": "^15.18.0",
    "cypress-axe": "^1.7.0",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "multiple-cucumber-html-reporter": "^3.10.0"
  },
  "dependencies": {
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/ollama": "^1.3.0",
    "cheerio": "^1.1.0",
    "dotenv": "^17.4.2",
    "langchain": "^1.5.2"
  }
}